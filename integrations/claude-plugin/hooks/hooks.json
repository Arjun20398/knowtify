{
  "description": "Knowtify — route permission prompts to desktop notifications",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/permission-request.mjs\"",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
