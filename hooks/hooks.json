{
  "description": "Knowtify — route permission prompts and 'waiting for input' to desktop dialogs",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/permission-request.mjs\"",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/stop.mjs\"",
            "timeout": 1800
          }
        ]
      }
    ]
  }
}
